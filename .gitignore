# ===== Python =====
.venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage

# ===== Node.js =====
node_modules/

# ===== Build artifacts =====
dist/
build/

# ===== Logs =====
# *.log catches Stage 24's source/runtime-health.log — that file is a
# regeneratable snapshot (scripts/runtime_health_snapshot.sh writes it)
# and must never be committed.
*.log
logs/

# ===== Stage 24 backup artifacts (never commit) =====
backups/
*.dump
*.sql.gz
*.enc

# ===== Stage 51 Backup / DR runtime artifacts (never commit) =====
# The Backup / DR gap-closure run writes a test-only encryption key, plain +
# encrypted backup dumps, mock off-host copies, and a facts file under a runtime
# dir. NONE may be committed. The readiness *snapshot* (booleans + key_id label,
# no secrets) is a regeneratable runtime artifact and is also gitignored.
.runtime/
source/dr-reports/backup_dr_readiness_latest.json
source/dr-reports/backup_dr_readiness_*.json

# ===== Environment & local secrets (never commit secrets) =====
.env
.env.*
*.env
!.env.example
# Stage 25: generated staging env files carry a random Postgres password.
# Keep the `.env.staging.local` shape gitignored regardless of where it
# sits in the tree.
infra/runtime/.env.staging.local
infra/runtime/.env.*.local
# Stage 26: mock-vault local fixture carries a generated DB password.
# Never commit. The committed example template ships placeholder
# values only.
infra/runtime/.mock-vault-secrets.local.json
infra/runtime/.mock-vault-secrets.*.local.json
secrets/
# Stage 24: shared/sdk/secrets/ holds the SecretProvider SDK (no real
# secret bytes). The directory name collided with the broader
# secrets/ ignore above — unignore the Python sources only.
!shared/sdk/secrets/
!shared/sdk/secrets/*.py
*.secret
*.key
*.pem
*.p12
credentials.json

# ===== Docker local volumes / runtime data =====
volumes/
docker-data/
.docker/

# ===== OS / editor cruft =====
.DS_Store
Thumbs.db
.idea/
*.swp

# ===== Local tooling config =====
.claude/

# ===== Stage 28 controlled code generation workspaces =====
# The development-agent writes generated artifacts under
# ``.workspaces/<task_id>/`` (or ``$DEVELOPMENT_AGENT_WORKSPACE_ROOT``
# which defaults to ``/tmp/aiagents-workspaces``). These are operator
# review artifacts only — they MUST NOT be committed. Real generated
# code lands in the repo only after a human reviewer ports it manually.
.workspaces/
.workspaces/**

# ===== Stage 47 Real Repo Workspace Operator generated workspaces =====
# The workspace-operator-agent writes controlled generated projects under
# ``$WORKSPACE_OPERATOR_ROOT`` (default ``/tmp/aiagents-workspaces``) or the
# repo-internal ``.generated-workspaces/`` root. Generated FastAPI Todo code,
# test reports, and workspace archives are operator review artifacts ONLY and
# MUST NOT be committed to the main repo.
.generated-workspaces/
.generated-workspaces/**

# ===== Stage 42 audit chain forensic artifacts =====
# Forensic *reports* (source/audit-forensics/*.json) are redacted and may
# be committed. Forensic *snapshots* contain (redacted) full payload rows
# and repair reports may reference row content — keep both out of git.
source/audit-forensics/snapshots/
source/audit-forensics/audit_forensic_*.json
source/audit-forensics/audit_forensic_latest.json
source/audit-forensics/audit_repair_*.json
source/audit-forensics/audit_repair_latest.json
source/audit-forensics/audit_log_restore_*.json
# Stage 44 runtime artifacts (lock + residue reports) -- regeneratable.
source/audit-forensics/audit_verification_lock_latest.json
source/audit-forensics/audit_tamper_residue_*.json
