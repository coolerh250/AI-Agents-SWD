{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "ai-agents-platform Step 51.1 foundation values",
  "type": "object",
  "additionalProperties": false,
  "required": ["global", "components"],
  "definitions": {
    "datastoreStorage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "persistenceEnabled", "accessMode", "size"],
      "properties": {
        "strategy": { "enum": ["generatedPVC", "existingClaim", "externalService"] },
        "persistenceEnabled": { "type": "boolean" },
        "existingClaim": { "type": "string" },
        "accessMode": { "enum": ["ReadWriteOnce", "ReadWriteMany", "ReadOnlyMany"] },
        "size": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ti)$" },
        "storageClassName": { "type": "string" },
        "mountPath": { "type": "string", "pattern": "^/.+" }
      },
      "allOf": [
        {
          "if": { "properties": { "strategy": { "const": "generatedPVC" } } },
          "then": { "properties": { "accessMode": { "const": "ReadWriteOnce" } } }
        }
      ]
    },
    "batchSecretRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "key": { "type": "string", "minLength": 1 }
      }
    },
    "appStorage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "persistenceEnabled"],
      "properties": {
        "strategy": { "enum": ["ephemeralEmptyDir", "existingClaim", "externalObjectStorePlaceholder", "unresolved"] },
        "persistenceEnabled": { "type": "boolean" },
        "existingClaim": { "type": "string" },
        "accessMode": { "enum": ["ReadWriteOnce", "ReadWriteMany", "ReadOnlyMany"] },
        "size": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ti)$" },
        "storageClassName": { "type": "string" },
        "productionConfigured": { "type": "boolean" }
      }
    }
  },
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": true,
      "required": ["environment", "production", "realDeployEnabled"],
      "properties": {
        "environment": {
          "type": "string",
          "enum": ["dev", "test", "staging", "production"]
        },
        "production": { "type": "boolean" },
        "realDeployEnabled": { "type": "boolean" },
        "imageRegistry": { "type": "string" },
        "imagePullSecrets": { "type": "array" },
        "nameOverride": { "type": "string" },
        "workloadSecurity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled", "runAsNonRoot", "runAsUser", "runAsGroup",
            "seccompProfile", "allowPrivilegeEscalation", "privileged",
            "readOnlyRootFilesystem", "dropCapabilities", "automountServiceAccountToken"
          ],
          "properties": {
            "enabled": { "type": "boolean" },
            "profile": { "type": "string" },
            "runAsNonRoot": { "const": true },
            "runAsUser": { "type": "integer", "minimum": 1 },
            "runAsGroup": { "type": "integer", "minimum": 1 },
            "fsGroup": { "type": "integer", "minimum": 1 },
            "seccompProfile": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type"],
              "properties": { "type": { "enum": ["RuntimeDefault"] } }
            },
            "allowPrivilegeEscalation": { "const": false },
            "privileged": { "const": false },
            "readOnlyRootFilesystem": { "type": "boolean" },
            "dropCapabilities": {
              "type": "array",
              "contains": { "const": "ALL" },
              "items": { "type": "string" }
            },
            "automountServiceAccountToken": { "const": false }
          }
        }
      }
    },
    "platform": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "adminConsole": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "authMode": { "type": "string" },
            "testAuthEnabled": { "type": "boolean" },
            "productionAuthEnabled": { "type": "boolean" },
            "oidcEnabled": { "type": "boolean" },
            "operatorActionsEnabled": { "type": "boolean" },
            "operatorActionsControlledOnly": { "type": "boolean" }
          }
        },
        "integrations": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "githubWrite": { "type": "boolean" },
            "prCreation": { "type": "boolean" },
            "deployment": { "type": "boolean" },
            "realLlm": { "type": "boolean" },
            "externalDelivery": { "type": "boolean" },
            "productionBackupSchedule": { "type": "boolean" }
          }
        }
      }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "existingSecret": { "type": "string" },
        "create": { "type": "boolean" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "create": { "type": "boolean" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "replicas": { "type": "integer", "minimum": 0 },
        "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
        "strategy": { "type": "object" },
        "podSecurityContext": { "type": "object" },
        "containerSecurityContext": { "type": "object" }
      }
    },
    "commonSecretRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "keys"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "keys": { "type": "object" }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "defaultDenyIngress", "defaultDenyEgress", "dns", "internalEdges"],
      "properties": {
        "enabled": { "const": true },
        "defaultDenyIngress": { "type": "boolean" },
        "defaultDenyEgress": { "type": "boolean" },
        "dns": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "namespaceSelector", "podSelector", "ports"],
          "properties": {
            "enabled": { "type": "boolean" },
            "namespaceSelector": { "type": "object", "minProperties": 1 },
            "podSelector": { "type": "object", "minProperties": 1 },
            "ports": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["protocol", "port"],
                "properties": {
                  "protocol": { "enum": ["TCP", "UDP"] },
                  "port": { "const": 53 }
                }
              }
            }
          }
        },
        "ingressController": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "namespaceSelector": { "type": "object" },
            "podSelector": { "type": "object" },
            "ports": { "type": "array", "items": { "type": "integer", "minimum": 1, "maximum": 65535 } }
          }
        },
        "observability": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "prometheusScrape": { "type": "object", "properties": { "enabled": { "type": "boolean" } } },
            "otlpExport": { "type": "object", "properties": { "enabled": { "type": "boolean" } } }
          }
        },
        "externalEgress": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "enabled": { "type": "boolean" } }
        },
        "internalEdges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "target", "protocol", "port"],
            "properties": {
              "source": { "type": "string", "minLength": 1 },
              "target": { "type": "string", "minLength": 1 },
              "protocol": { "enum": ["TCP", "UDP"] },
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "required": { "type": "boolean" },
              "infra": { "type": "boolean" }
            }
          }
        }
      }
    },
    "externalDataServices": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["enabled", "cidrs", "port"],
        "properties": {
          "enabled": { "type": "boolean" },
          "cidrs": {
            "type": "array",
            "items": {
              "type": "string",
              "not": { "enum": ["0.0.0.0/0", "::/0"] }
            }
          },
          "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
        }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "postgres": { "$ref": "#/definitions/datastoreStorage" },
        "redis": { "$ref": "#/definitions/datastoreStorage" },
        "workspace": { "$ref": "#/definitions/appStorage" },
        "artifacts": { "$ref": "#/definitions/appStorage" }
      }
    },
    "batchJobs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "serviceAccounts": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "create": { "type": "boolean" } }
        },
        "image": {
          "type": "object",
          "required": ["repository"],
          "additionalProperties": false,
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "digest": { "type": "string" }
          }
        },
        "resources": { "type": "object" },
        "migration": {
          "type": "object",
          "additionalProperties": false,
          "required": ["renderTemplate", "executionEnabled", "commandKey", "backoffLimit", "activeDeadlineSeconds", "ttlSecondsAfterFinished"],
          "properties": {
            "renderTemplate": { "type": "boolean" },
            "executionEnabled": { "type": "boolean" },
            "commandKey": { "const": "migration" },
            "backoffLimit": { "type": "integer", "minimum": 0, "maximum": 0 },
            "activeDeadlineSeconds": { "type": "integer", "minimum": 1 },
            "ttlSecondsAfterFinished": { "type": "integer", "minimum": 1 },
            "lock": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "required": { "type": "boolean" },
                "mode": { "enum": ["postgres_advisory_lock"] }
              }
            },
            "secretRef": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "databaseUrlKey": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "backup": {
          "type": "object",
          "additionalProperties": false,
          "required": ["renderTemplate", "scheduleEnabled", "suspend", "commandKey", "schedule", "concurrencyPolicy", "backoffLimit", "activeDeadlineSeconds", "ttlSecondsAfterFinished"],
          "properties": {
            "renderTemplate": { "type": "boolean" },
            "scheduleEnabled": { "type": "boolean" },
            "suspend": { "type": "boolean" },
            "commandKey": { "const": "encrypted-backup" },
            "schedule": { "type": "string", "minLength": 1 },
            "concurrencyPolicy": { "const": "Forbid" },
            "startingDeadlineSeconds": { "type": "integer", "minimum": 1 },
            "backoffLimit": { "type": "integer", "minimum": 0, "maximum": 0 },
            "activeDeadlineSeconds": { "type": "integer", "minimum": 1 },
            "ttlSecondsAfterFinished": { "type": "integer", "minimum": 1 },
            "successfulJobsHistoryLimit": { "type": "integer", "minimum": 0 },
            "failedJobsHistoryLimit": { "type": "integer", "minimum": 0 },
            "secretRefs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "database": { "$ref": "#/definitions/batchSecretRef" },
                "encryption": { "$ref": "#/definitions/batchSecretRef" }
              }
            },
            "target": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "strategy": { "enum": ["disabled", "existingClaim", "externalObjectStorePlaceholder"] },
                "existingClaim": { "type": "string" },
                "externalObjectStoreEnabled": { "type": "boolean" }
              }
            }
          }
        },
        "restore": {
          "type": "object",
          "additionalProperties": false,
          "required": ["renderTemplate", "executionEnabled", "commandKey", "backoffLimit", "activeDeadlineSeconds", "ttlSecondsAfterFinished", "targetPrefix"],
          "properties": {
            "renderTemplate": { "type": "boolean" },
            "executionEnabled": { "type": "boolean" },
            "commandKey": { "const": "isolated-restore-drill" },
            "backoffLimit": { "type": "integer", "minimum": 0, "maximum": 0 },
            "activeDeadlineSeconds": { "type": "integer", "minimum": 1 },
            "ttlSecondsAfterFinished": { "type": "integer", "minimum": 1 },
            "targetPrefix": { "const": "aiagents_restore_drill_" },
            "secretRefs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "source": { "$ref": "#/definitions/batchSecretRef" },
                "target": { "$ref": "#/definitions/batchSecretRef" },
                "encryption": { "$ref": "#/definitions/batchSecretRef" }
              }
            }
          }
        }
      }
    },
    "batchCommands": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "args", "shell"],
        "properties": {
          "command": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "args": { "type": "array", "items": { "type": "string" } },
          "shell": { "const": false }
        }
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["enabled", "type", "image"],
        "properties": {
          "enabled": { "type": "boolean" },
          "type": {
            "type": "string",
            "enum": ["application", "governance", "communication", "worker", "agent", "infrastructure"]
          },
          "testOnly": { "type": "boolean" },
          "replicas": { "type": "integer", "minimum": 0 },
          "containerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "command": { "type": "array" },
          "useCommonSecretRefs": { "type": "boolean" },
          "env": { "type": "object" },
          "security": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "runAsUser": { "type": "integer", "minimum": 1 },
              "runAsGroup": { "type": "integer", "minimum": 1 },
              "fsGroup": { "type": "integer", "minimum": 1 },
              "readOnlyRootFilesystem": { "type": "boolean" },
              "writablePaths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "mountPath", "sizeLimit"],
                  "properties": {
                    "name": { "type": "string", "minLength": 1 },
                    "mountPath": { "type": "string", "pattern": "^/.+" },
                    "sizeLimit": { "type": "string", "minLength": 1 },
                    "medium": { "type": "string" }
                  }
                }
              }
            }
          },
          "image": {
            "type": "object",
            "required": ["repository"],
            "additionalProperties": false,
            "properties": {
              "repository": { "type": "string", "minLength": 1 },
              "tag": { "type": "string" },
              "digest": { "type": "string" }
            }
          },
          "service": {
            "type": "object",
            "required": ["enabled", "port"],
            "additionalProperties": false,
            "properties": {
              "enabled": { "type": "boolean" },
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
            }
          },
          "health": {
            "type": "object",
            "additionalProperties": true,
            "required": ["enabled", "type"],
            "properties": {
              "enabled": { "type": "boolean" },
              "type": { "type": "string", "enum": ["httpGet", "exec"] },
              "path": { "type": "string" },
              "command": { "type": "array" },
              "initialDelaySeconds": { "type": "integer", "minimum": 0 },
              "periodSeconds": { "type": "integer", "minimum": 1 }
            }
          },
          "resources": {
            "type": "object",
            "required": ["requests", "limits"],
            "additionalProperties": false,
            "properties": {
              "requests": {
                "type": "object",
                "required": ["cpu", "memory"],
                "additionalProperties": false,
                "properties": {
                  "cpu": { "type": ["string", "number"] },
                  "memory": { "type": "string" }
                }
              },
              "limits": {
                "type": "object",
                "required": ["cpu", "memory"],
                "additionalProperties": false,
                "properties": {
                  "cpu": { "type": ["string", "number"] },
                  "memory": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
