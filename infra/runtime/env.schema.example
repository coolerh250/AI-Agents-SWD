# AI Agents SWD — runtime env schema.
#
# Stage 24 baseline. This file is a SCHEMA — every value below is a
# placeholder that MUST be replaced with a real value in the operator's
# private shell / secret manager before launching staging. Do NOT
# commit a file with real secrets to the repo.
#
# Local/test default is the platform's existing docker-compose.yml; the
# values below describe what an operator would set when promoting the
# platform to staging.

# ---------- platform mode ----------
# local | staging | production-check
# The runtime validator (scripts/validate_runtime_config.py) keys off
# this. ``local`` keeps trust-auth / dev-mode tolerances. ``staging``
# tightens to require real auth + non-placeholder secrets. ``production
# -check`` is a read-only gate the validator can run against any cluster.
APP_ENV=local

# ---------- core URLs ----------
DATABASE_URL=postgresql://postgres@postgres:5432/aiagents
REDIS_URL=redis://redis:6379
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
ALERTMANAGER_WEBHOOK_URL=PLACEHOLDER_DO_NOT_COMMIT_REAL_VALUE

# ---------- Postgres (staging needs a real password — local uses trust) ----------
POSTGRES_USER=postgres
POSTGRES_DB=aiagents
POSTGRES_PASSWORD=PLACEHOLDER_DO_NOT_COMMIT_REAL_VALUE

# ---------- Vault ----------
# Local/test runs Vault in dev mode; staging must point at a real Vault
# server and the token must come from the operator's shell, never a file.
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=PLACEHOLDER_DO_NOT_COMMIT_REAL_VALUE

# ---------- GitHub integration (controlled-real Stage 23) ----------
# Sandbox-by-default. The three GITHUB_* vars below MUST all be set
# before the safety guard allows /github/workflow/real-test-pr to issue
# a real GitHub call. GITHUB_TOKEN must never be committed.
GITHUB_TOKEN=PLACEHOLDER_DO_NOT_COMMIT_REAL_VALUE
GITHUB_TEST_REPO=
RUN_REAL_GITHUB_TEST=false

# ---------- Discord integration (controlled-real Stage 22) ----------
# Sandbox-by-default. DISCORD_BOT_TOKEN must never be committed.
DISCORD_BOT_TOKEN=PLACEHOLDER_DO_NOT_COMMIT_REAL_VALUE
DISCORD_TEST_CHANNEL_ID=
RUN_REAL_DISCORD_TEST=false

# ---------- Stage 24 escape hatches ----------
# Set ALLOW_VAULT_DEV_MODE_FOR_STAGING=true ONLY if you knowingly accept
# the risk of running staging with Vault dev mode (e.g. a short
# integration smoke). The validator refuses staging unless this is
# explicitly true OR the Vault address points outside the dev container.
ALLOW_VAULT_DEV_MODE_FOR_STAGING=false
