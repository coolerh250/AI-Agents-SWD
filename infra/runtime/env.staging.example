# Staging env template — Stage 24 hardening baseline.
#
# DO NOT COMMIT a populated copy of this file. Every line below is a
# placeholder; the operator is expected to drop a real value into their
# shell (or a private secret manager) before running
# `docker compose -f infra/docker-compose/docker-compose.staging.yml up`.
#
# Differences vs env.schema.example:
# * APP_ENV is fixed to `staging` so validate_runtime_config.py runs the
#   staging checks.
# * POSTGRES_PASSWORD MUST be set to a real value — staging refuses
#   trust-auth.
# * GITHUB_TOKEN / DISCORD_BOT_TOKEN are still optional; the platform
#   defaults to sandbox-only and the opt-in real-test guards stay in
#   force.
# * ALLOW_VAULT_DEV_MODE_FOR_STAGING is intentionally `false`. Flipping
#   it to `true` is a documented escape hatch for short integration
#   smokes — do not leave it on.

APP_ENV=staging

DATABASE_URL=postgresql://aiagents_app:PLACEHOLDER_DO_NOT_COMMIT_REAL_VALUE@postgres:5432/aiagents
REDIS_URL=redis://redis:6379
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
ALERTMANAGER_WEBHOOK_URL=PLACEHOLDER_DO_NOT_COMMIT_REAL_VALUE

POSTGRES_USER=aiagents_app
POSTGRES_DB=aiagents
POSTGRES_PASSWORD=PLACEHOLDER_DO_NOT_COMMIT_REAL_VALUE

VAULT_ADDR=PLACEHOLDER_DO_NOT_COMMIT_REAL_VALUE
VAULT_TOKEN=PLACEHOLDER_DO_NOT_COMMIT_REAL_VALUE

# Controlled-real GitHub validation. Leave RUN_REAL_GITHUB_TEST=false
# unless an operator is explicitly opting in to one PR-scoped sandbox
# write. The guard pins repo == GITHUB_TEST_REPO.
GITHUB_TOKEN=PLACEHOLDER_DO_NOT_COMMIT_REAL_VALUE
GITHUB_TEST_REPO=
RUN_REAL_GITHUB_TEST=false

# Controlled-real Discord delivery. Default off.
DISCORD_BOT_TOKEN=PLACEHOLDER_DO_NOT_COMMIT_REAL_VALUE
DISCORD_TEST_CHANNEL_ID=
RUN_REAL_DISCORD_TEST=false

# Stage 24 escape hatch. Flip to true ONLY for a short Vault-dev-mode
# integration smoke; never leave on.
ALLOW_VAULT_DEV_MODE_FOR_STAGING=false

# Stage 26: SecretProvider selection. `mock-vault` reads
# infra/runtime/.mock-vault-secrets.local.json (gitignored, generated
# by scripts/bootstrap_mock_vault_secrets.sh) and is the default for
# staging validation. `vault` requires real VAULT_ADDR + VAULT_TOKEN.
# `env` falls back to the host environment.
SECRET_PROVIDER=mock-vault
VAULT_KV_MOUNT=secret
VAULT_KV_PATH=aiagents/staging
MOCK_VAULT_SECRETS_FILE=/run/secrets/mock-vault-secrets.json
