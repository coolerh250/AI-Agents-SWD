{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Active alerts (firing)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {"expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)", "legendFormat": "firing", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "red", "value": 1}
          ]}
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Workflows dispatched (total)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {"expr": "sum(workflow_total)", "legendFormat": "dispatched", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "type": "stat",
      "title": "Workflows completed",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {"expr": "sum(workflow_completed_total)", "legendFormat": "completed", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "type": "stat",
      "title": "Workflows failed / canceled / aborted",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [
        {"expr": "sum by (reason) (workflow_failed_total)", "legendFormat": "{{reason}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "type": "table",
      "title": "Service health (up per job)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "up", "legendFormat": "{{job}}", "refId": "A", "format": "table", "instant": true}
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [
          {"color": "red", "value": null},
          {"color": "green", "value": 1}
        ]}},
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Active alerts over time",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "sum by (alertname, severity) (ALERTS{alertstate=\"firing\"})", "legendFormat": "{{alertname}} [{{severity}}]", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "type": "timeseries",
      "title": "Agent execution rate (per agent)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "sum by (agent) (rate(agent_execution_total[5m]))", "legendFormat": "{{agent}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "type": "timeseries",
      "title": "Agent latency p95 (seconds)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, agent) (rate(agent_latency_seconds_bucket[5m])))", "legendFormat": "{{agent}} p95", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "type": "timeseries",
      "title": "Workflow duration p95 (seconds)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(workflow_duration_seconds_bucket[5m])))", "legendFormat": "workflow p95", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "type": "timeseries",
      "title": "Retry / deadletter activity",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [
        {"expr": "sum by (kind) (rate(retry_total[5m]))", "legendFormat": "retry {{kind}}", "refId": "A"},
        {"expr": "sum by (original_stream) (rate(deadletter_total[5m]))", "legendFormat": "dlq {{original_stream}}", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "type": "stat",
      "title": "Dead-letter total",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 28},
      "targets": [
        {"expr": "sum(deadletter_total)", "legendFormat": "deadletter", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "type": "stat",
      "title": "Retry totals (by kind)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 28},
      "targets": [
        {"expr": "sum by (kind) (retry_total)", "legendFormat": "{{kind}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "type": "stat",
      "title": "Notifications total (by event_type)",
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 28},
      "targets": [
        {"expr": "sum by (event_type) (notification_total)", "legendFormat": "{{event_type}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["aiagents", "observability", "alerting"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
